{
  "threshold": 0,
  "reporters": ["console", "json"],
  "output": ".jscpd-report",
  "ignore": [
    "**/node_modules/**",
    "**/_site/**",
    "**/.build/**",
    "**/packages/**",
    "**/chobble-template/**",
    "**/wp-content/**",
    "**/wp-includes/**"
  ],
  "format": ["javascript", "markup", "css"],
  "absolute": false,
  "gitignore": true,
  "exitCode": 1,
  "minLines": 3,
  "minTokens": 50,
  "path": ["."]
}
